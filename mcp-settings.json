{
  "mcpServers": {
    "advisor-mcp-server": {
      "command": "bash",
      "args": ["-c", "advisor mcp"],
      "transportType": "stdio",
      "env": {
        "ADVISOR_SERVER": "http://localhost:9003",
        "ARTIFACTORY_REPOSITORY_URL": "http://localhost:8082/artifactory"
      }
    }
  }
}

